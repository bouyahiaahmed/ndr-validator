# =============================================================================
# NDR Pipeline Validator – Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# ── Core ──────────────────────────────────────────────────────────────────────
APP_ENV=prod
LOG_LEVEL=INFO
SCRAPE_INTERVAL_SECONDS=30
REQUEST_TIMEOUT_SECONDS=5
SQLITE_DB_PATH=/data/validator.db
TZ=UTC

# ── Sensors ───────────────────────────────────────────────────────────────────
# Comma-separated list of sensor IPs
SENSOR_LIST=10.0.0.11,10.0.0.12,10.0.0.13
EXPECTED_SENSOR_COUNT=3
# JSON map of IP → display name
SENSOR_NAME_MAP_JSON={"10.0.0.11":"sensor1","10.0.0.12":"sensor2","10.0.0.13":"sensor3"}

# ── SSH Probing (optional – Zeek direct checks) ───────────────────────────────
ENABLE_SENSOR_SSH=false
SENSOR_SSH_USER=vagrant
SENSOR_SSH_PORT=22
# Path inside container; mount the key via volumes in docker-compose.yml
SENSOR_SSH_KEY_PATH=/run/secrets/sensor_ssh_key
SENSOR_SSH_CONNECT_TIMEOUT_SECONDS=5
ZEEK_LOG_DIR=/opt/zeek/logs/current
ZEEK_SERVICE_NAME=zeek
VECTOR_SERVICE_NAME=vector
# Local path to SSH key on the Docker host (used by docker-compose volume mount)
SSH_KEY_LOCAL_PATH=./secrets/sensor_ssh_key

# ── Vector Metrics ────────────────────────────────────────────────────────────
VECTOR_METRICS_SCHEME=http
VECTOR_METRICS_PORT=9598
VECTOR_METRICS_PATH=/metrics

# ── Data Prepper Management ───────────────────────────────────────────────────
DATAPREPPER_HOST=dataprepper
DATAPREPPER_METRICS_SCHEME=https
DATAPREPPER_METRICS_PORT=4900
DATAPREPPER_METRICS_PATH=/metrics/sys
DATAPREPPER_USERNAME=admin
DATAPREPPER_PASSWORD=changeme

# ── Data Prepper Ingest ───────────────────────────────────────────────────────
DATAPREPPER_INGEST_SCHEME=https
DATAPREPPER_INGEST_PORT=2021
DATAPREPPER_INGEST_PATH=/log/ingest
DATAPREPPER_HEALTH_PATH=/health
DATAPREPPER_INGEST_USERNAME=vector
DATAPREPPER_INGEST_PASSWORD=changeme
DATAPREPPER_HEALTH_REQUIRES_AUTH=true

# ── OpenSearch ────────────────────────────────────────────────────────────────
OPENSEARCH_SCHEME=https
OPENSEARCH_HOST=opensearch-node1
OPENSEARCH_PORT=9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=changeme
# OPENSEARCH_INDEX_PATTERN can be narrowed to specific log types for freshness/search/data-quality.
# Example: zeek-conn-*,zeek-dns-*,zeek-http-*,zeek-ssl-*,zeek-files-*
# If narrowed, set DP_TO_OS_CORRELATION_INDEX_PATTERN to the broader pattern used
# for drop-rate correlation (which must match the scope of Data Prepper output metrics).
OPENSEARCH_INDEX_PATTERN=zeek-*
OPENSEARCH_SENSOR_ID_FIELD=host.name.keyword
OPENSEARCH_LOG_TYPE_FIELD=log_type.keyword
OPENSEARCH_TIMESTAMP_FIELD=@timestamp

# ── OpenSearch Dashboards ─────────────────────────────────────────────────────
DASHBOARDS_SCHEME=https
DASHBOARDS_HOST=dashboards
DASHBOARDS_PORT=5601
DASHBOARDS_BASE_PATH=
DASHBOARDS_USERNAME=admin
DASHBOARDS_PASSWORD=changeme
DASHBOARDS_STATUS_PATH=/api/status
DASHBOARDS_ENABLE_STATUS_API_CHECK=true

# ── Certificates ──────────────────────────────────────────────────────────────
# Local path to CA cert directory on Docker host
CA_CERT_LOCAL_PATH=./certs/ca
# Path inside container (do not change unless you also change the volume mount)
CA_CERT_PATH=/certs/ca/ca.crt
DASHBOARDS_CA_CERT_PATH=/certs/ca/ca.crt
# Optional mutual TLS client certs (leave empty if not used)
OPENSEARCH_CLIENT_CERT_PATH=
OPENSEARCH_CLIENT_KEY_PATH=
DATAPREPPER_CLIENT_CERT_PATH=
DATAPREPPER_CLIENT_KEY_PATH=
CLIENT_CERT_LOCAL_PATH=./certs/client

# ── Thresholds ────────────────────────────────────────────────────────────────
STALE_DATA_THRESHOLD_SECONDS=120
CRITICAL_STALE_DATA_THRESHOLD_SECONDS=300
MAX_VECTOR_TO_DP_DROP_PERCENT=5
MAX_DP_TO_OS_DROP_PERCENT=5
MAX_DP_PIPELINE_LATENCY_SECONDS_WARN=5
MAX_DP_PIPELINE_LATENCY_SECONDS_CRIT=30
MAX_DP_BUFFER_USAGE_RATIO_WARN=0.7
MAX_DP_BUFFER_USAGE_RATIO_CRIT=0.9
MAX_DP_BUFFER_WRITE_FAILURE_DELTA=0
MAX_DP_DOCUMENT_ERROR_DELTA=0
MAX_DP_BULK_FAILURE_DELTA=0
MAX_DP_TLS_HANDSHAKE_FAILURE_DELTA=0
MAX_OS_SEARCH_LATENCY_MS_WARN=500
MAX_OS_SEARCH_LATENCY_MS_CRIT=2000
LOW_DISK_THRESHOLD_PERCENT=15
HIGH_HEAP_THRESHOLD_PERCENT=85
REQUIRED_LOG_TYPES=conn,dns,http,ssl,files
# REQUIRED_FIELDS can be ECS fields or raw Zeek fields depending on deployment maturity.
# Early deployments using raw Zeek fields:
#   REQUIRED_FIELDS=@timestamp,id.orig_h,id.resp_h,proto
# ECS-normalised deployments:
#   REQUIRED_FIELDS=@timestamp,source.ip,destination.ip,network.protocol
# The validator reads both literal dotted keys ("id.orig_h") and nested objects ({"id":{"orig_h":".."}}).
REQUIRED_FIELDS=@timestamp,source.ip,destination.ip,network.protocol

# ── Security ──────────────────────────────────────────────────────────────────
# DANGER: Only set to true for emergency TLS troubleshooting. Never in production.
ENABLE_DEBUG_INSECURE_SKIP_VERIFY=false

# ── DLQ Check (optional) ──────────────────────────────────────────────────────
ENABLE_DP_DLQ_CHECK=false
DP_DLQ_GLOB=/tmp/dp-dlq-*.log

# ── Drop-Rate Correlation ─────────────────────────────────────────────────────
# When OPENSEARCH_INDEX_PATTERN is narrowed (e.g. zeek-conn-*,zeek-dns-*,...)
# the OS doc count only covers a subset of log types while Data Prepper metrics
# count all log types.  Set this to the broader pattern so drop-rate comparison
# uses the correct scope.  Leave empty to auto-detect scope mismatch (emits
# UNKNOWN instead of a false drop-rate RED).
DP_TO_OS_CORRELATION_INDEX_PATTERN=
